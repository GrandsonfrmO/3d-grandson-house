# Configuration locale pour développement

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/email_app"

# JWT
JWT_SECRET="dev-secret-key-change-in-production"

# Admin credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Resend Email Service
# Obtenez votre clé API sur https://resend.com/api-keys
RESEND_API_KEY="re_test_key_here"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Environment
NODE_ENV="development"
PORT="5000"

# Logging
LOG_LEVEL="debug"

# Optional: Email for health checks
ADMIN_EMAIL="admin@example.com"
