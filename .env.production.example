# Configuration de production - À configurer avec vos vraies valeurs

# Database
DATABASE_URL="postgresql://user:password@prod-db.example.com:5432/email_app"

# JWT
JWT_SECRET="your-very-secure-secret-key-change-this"

# Admin credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="very-secure-password-change-this"

# Resend Email Service
RESEND_API_KEY="re_your_production_key_here"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Gemini AI
GEMINI_API_KEY="your-gemini-production-key"
APP_URL="https://yourdomain.com"

# Environment
NODE_ENV="production"
PORT="5000"

# Logging
LOG_LEVEL="info"

# Optional: Email for health checks and alerts
ADMIN_EMAIL="admin@yourdomain.com"

# Optional: Monitoring and alerting
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
DATADOG_API_KEY="your-datadog-api-key"

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# Optional: Email retry configuration
EMAIL_RETRY_ATTEMPTS="3"
EMAIL_RETRY_DELAY_MS="1000"

# Optional: CORS configuration
CORS_ORIGIN="https://yourdomain.com"

# Optional: API documentation
API_DOCS_ENABLED="false"

# Localization Settings
VITE_LANGUAGE=fr
VITE_CURRENCY=GNF
