# Configuration de staging

# Database
DATABASE_URL="postgresql://user:password@staging-db.example.com:5432/email_app_staging"

# JWT
JWT_SECRET="your-staging-secret-key"

# Admin credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="staging-password"

# Resend Email Service
RESEND_API_KEY="re_your_staging_key_here"
RESEND_FROM_EMAIL="noreply-staging@yourdomain.com"

# Gemini AI
GEMINI_API_KEY="your-gemini-staging-key"
APP_URL="https://staging.yourdomain.com"

# Environment
NODE_ENV="staging"
PORT="5000"

# Logging
LOG_LEVEL="debug"

# Optional: Email for health checks and alerts
ADMIN_EMAIL="admin@yourdomain.com"

# Optional: Monitoring and alerting
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# Optional: CORS configuration
CORS_ORIGIN="https://staging.yourdomain.com"

# Optional: API documentation
API_DOCS_ENABLED="true"

# Localization Settings
VITE_LANGUAGE=fr
VITE_CURRENCY=GNF
